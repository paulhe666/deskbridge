{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deskbridge",
  "version": "1.5.9",
  "identifier": "local.deskbridge.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deskbridge",
        "width": 880,
        "height": 600,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/deskbridge.png",
      "assets/deskbridge.icns",
      "assets/deskbridge.ico"
    ]
  }
}
